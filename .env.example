# ─── API Keys ──────────────────────────────────────────────────────────────
# Eventbrite: https://www.eventbrite.com/platform/ → crea app → copia API key
EVENTBRITE_API_KEY=

# Groq (LLM filter): https://console.groq.com → API Keys → Create (gratuito)
GROQ_API_KEY=

# Reddit: https://www.reddit.com/prefs/apps → crea "script" app → copia client_id e secret
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Telegram: parla con @BotFather su Telegram → /newbot → copia token
# Per il CHAT_ID: parla con @userinfobot o manda un messaggio al bot e chiama
# https://api.telegram.org/bot<TOKEN>/getUpdates per trovare il tuo chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Meetup (opzionale): https://www.meetup.com/api/ → OAuth consumer
# Se non impostato, il collector usa solo HTML scraping
MEETUP_API_KEY=
